{
  "name": "nix-pres-draft",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "slidev --open",
    "build": "slidev build",
    "export": "slidev export",
    "fmt": "prettier --write . && node scripts/check-slides.mjs slides.md --fix --quiet",
    "fmt:check": "prettier --check .",
    "check": "node scripts/check-slides.mjs slides.md",
    "check:fix": "node scripts/check-slides.mjs slides.md --fix",
    "validate": "npm run check && npm run fmt:check && npm run build",
    "lint": "markdownlint-cli2 \"**/*.md\"",
    "deadcode": "knip"
  },
  "devDependencies": {
    "@iconify-json/circle-flags": "^1.2.10",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/simple-icons": "^1.2.90",
    "@iconify/vue": "^5.0.1",
    "@slidev/cli": "^52.16.0",
    "@slidev/theme-default": "^0.25.0",
    "knip": "^6.23.0",
    "markdownlint-cli2": "^0.22.1",
    "motion": "^12.42.2",
    "playwright": "^1.61.1",
    "playwright-chromium": "^1.60.0",
    "prettier": "^3.9.4",
    "vue": "^3.5.39"
  },
  "dependencies": {
    "motion-v": "^2.3.0"
  }
}
